Bootstrap: docker
From: nvidia/cuda:12.9.1-cudnn-devel-ubuntu22.04

%files
    SRK_Root_Cert.crt /usr/local/share/ca-certificates/SRK_Root_Cert.crt

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive
    export CUDA_VERSION=129
    export CPU_ARCH=x86_64

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        openssh-client \
        python3 \
        python3-dev \
        python3-pip
    update-ca-certificates
    rm -rf /var/lib/apt/lists/*

    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel uv
    export VLLM_VERSION="$(curl -fsSL https://api.github.com/repos/vllm-project/vllm/releases/latest | python3 -c "import json, sys; print(json.load(sys.stdin)['tag_name'].removeprefix('v'))")"

    # Install an explicit cu129 vLLM wheel; the torch backend only selects the
    # PyTorch index and does not constrain the vLLM binary variant.
    uv pip install --system \
        "https://github.com/vllm-project/vllm/releases/download/v${VLLM_VERSION}/vllm-${VLLM_VERSION}+cu${CUDA_VERSION}-cp38-abi3-manylinux_2_35_${CPU_ARCH}.whl" \
        --extra-index-url "https://download.pytorch.org/whl/cu${CUDA_VERSION}"
    python3 -m pip uninstall -y uv
    python3 -m pip install --no-cache-dir \
        "qwen-vl-utils"

    mkdir -p /workspace /workspace/.hf-cache /workspace/.hf-cache/hub /outputs /root/.ssh
    chmod 700 /root/.ssh

%environment
    export PYTHONUNBUFFERED=1
    export CUDA_HOME=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}
    export DO_NOT_TRACK=${DO_NOT_TRACK:-1}
    export HF_HOME=${HF_HOME:-/workspace/.hf-cache}
    export HF_HUB_CACHE=${HF_HUB_CACHE:-/workspace/.hf-cache/hub}
    export HF_HUB_DISABLE_TELEMETRY=${HF_HUB_DISABLE_TELEMETRY:-1}
    export HF_HUB_OFFLINE=${HF_HUB_OFFLINE:-1}
    export VLLM_CACHE_ROOT=${VLLM_CACHE_ROOT:-/dev/shm/vllm-cache}
    export VLLM_NO_USAGE_STATS=${VLLM_NO_USAGE_STATS:-1}
    export VLLM_RPC_BASE_PATH=${VLLM_RPC_BASE_PATH:-/dev/shm/vllm-rpc}
    export VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=${VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS:-1}

%runscript
    if [ "$#" -eq 0 ]; then
        exec /bin/bash
    fi

    exec "$@"

%test
    set -eux
    /usr/bin/python3 --version
    ssh -V
    /usr/bin/python3 -c "import torch; import vllm; print(torch.__version__); print(vllm.__version__)"
    ldd /usr/local/lib/python3.10/dist-packages/vllm/_C.abi3.so | tee /dev/stderr
    ! ldd /usr/local/lib/python3.10/dist-packages/vllm/_C.abi3.so | grep -F "libcudart.so.13"
