Bootstrap: docker
From: ubuntu:22.04

%files
    requirements-cuda.txt /tmp/requirements-cuda.txt

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        python-is-python3 \
        python3 \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    python3 -m pip install --no-cache-dir --upgrade pip

    python3 -m pip install --no-cache-dir \
        --index-url https://download.pytorch.org/whl/cu126 \
        torch

    python3 -m pip install --no-cache-dir -r /tmp/requirements-cuda.txt
    rm -f /tmp/requirements-cuda.txt

    mkdir -p /workspace /hf-cache

%environment
    export PYTHONUNBUFFERED=1
    export HF_HOME=${HF_HOME:-/hf-cache}
    export TRANSFORMERS_CACHE=${TRANSFORMERS_CACHE:-/hf-cache}

%runscript
    if [ "$#" -eq 0 ]; then
        exec /bin/bash
    fi

    exec /usr/bin/python3 "$@"

%test
    set -eux
    /usr/bin/python3 --version
    /usr/bin/python3 -c "import torch, transformers, accelerate; print(torch.__version__); print(transformers.__version__); print(accelerate.__version__)"
