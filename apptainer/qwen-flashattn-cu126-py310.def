Bootstrap: docker
From: nvidia/cuda:12.6.3-cudnn-devel-ubuntu22.04

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        git \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        ninja-build \
        python-is-python3 \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv
    rm -rf /var/lib/apt/lists/*

    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel packaging ninja uv

    python3 -m pip install --no-cache-dir \
        --index-url https://download.pytorch.org/whl/cu126 \
        torch \
        torchvision

    mkdir -p /workspace /hf-cache

%environment
    export PYTHONUNBUFFERED=1
    export CUDA_HOME=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}
    export HF_HOME=${HF_HOME:-/hf-cache}
    export TRANSFORMERS_CACHE=${TRANSFORMERS_CACHE:-/hf-cache}

%runscript
    if [ "$#" -eq 0 ]; then
        exec /bin/bash
    fi

    exec /usr/bin/python3 "$@"

%test
    set -eux
    /usr/bin/python3 --version
    uv --version
    nvcc --version
    /usr/bin/python3 -c "import torch; print(torch.__version__); print(torch.version.cuda); print(torch.cuda.is_available())"
